#!/bin/sh
# rpcd backend for luci-app-rm520n

AT_PORT=""
AT_LOCK="/tmp/.rm520n_at_lock"

_find_at_port() {
    for p in /dev/ttyUSB2 /dev/ttyUSB3 /dev/ttyUSB1 /dev/ttyUSB0; do
        [ -c "$p" ] && AT_PORT="$p" && return 0
    done
    return 1
}

_at_lock() {
    local tries=0
    while ! mkdir "$AT_LOCK" 2>/dev/null; do
        tries=$(( tries + 1 ))
        [ "$tries" -ge 30 ] && return 1
        sleep 1
    done
}

_at_unlock() { rmdir "$AT_LOCK" 2>/dev/null || true; }

_at() {
    local cmd="$1" max="${2:-4}" tmpf="/tmp/_rm520n_at_$$" dpid i result

    _at_lock || return 1

    exec 3<>"$AT_PORT"
    dd <&3 of="$tmpf" bs=1 count=256 2>/dev/null &
    dpid=$!
    printf '%s\r\n' "$cmd" >&3
    i=0
    while [ "$i" -lt "$max" ]; do
        sleep 1; i=$(( i + 1 ))
        grep -qE 'OK|ERROR' "$tmpf" 2>/dev/null && break
    done
    kill "$dpid" 2>/dev/null || true
    wait "$dpid" 2>/dev/null || true
    exec 3>&- 2>/dev/null || true

    result="$(cat "$tmpf" 2>/dev/null)"
    rm -f "$tmpf"
    _at_unlock
    printf '%s' "$result"
}

_json_str() { printf '"%s"' "$(printf '%s' "$1" | sed 's/\\/\\\\/g;s/"/\\"/g')"; }
_json_num() {
    case "$1" in
        -[0-9]*|[0-9]*) printf '%s' "$1" ;;
        *) printf 'null' ;;
    esac
}

_parse_qcsq() {
    # Sets tech/rssi/rsrp/sinr/rsrq from a qcsq string
    local qcsq="$1"
    tech="$(printf '%s' "$qcsq" | cut -d, -f1)"
    rssi="$(printf '%s' "$qcsq" | cut -d, -f2)"
    rsrp="$(printf '%s' "$qcsq" | cut -d, -f3)"
    sinr="$(printf '%s' "$qcsq" | cut -d, -f4)"
    rsrq="$(printf '%s' "$qcsq" | cut -d, -f5)"
}

# ── Combined methods (used by the LuCI view) ──────────────────────────────

# Returns all static + signal data in one call — avoids concurrent AT access
# from Promise.all() on the JS side.
_method_full_status() {
    _find_at_port || { printf '{"error":"AT port not found"}'; return; }

    local fw imei creg c5greg qcsq cell lte_bands nr_bands mode
    local tech rssi rsrp sinr rsrq

    fw="$(_at "ATI"                        | grep -i 'revision'    | head -1 | sed 's/.*Revision: *//' | tr -d '\r')"
    imei="$(_at "AT+GSN"                   | grep -E '^[0-9]{15}'  | head -1 | tr -d '\r')"
    creg="$(_at "AT+CREG?"                 | grep '+CREG:'         | head -1 | tr -d '\r')"
    c5greg="$(_at "AT+C5GREG?"             | grep '+C5GREG:'       | head -1 | tr -d '\r')"
    qcsq="$(_at "AT+QCSQ"                  | grep '^\+QCSQ'        | head -1 | sed 's/+QCSQ: //' | tr -d '\r"')"
    cell="$(_at 'AT+QENG="servingcell"'    | grep '^\+QENG'        | head -1 | tr -d '\r')"
    lte_bands="$(_at 'AT+QNWPREFCFG="lte_band"'   | grep '^\+QNWPREFCFG' | head -1 | tr -d '\r')"
    nr_bands="$(_at  'AT+QNWPREFCFG="nr5g_band"'  | grep '^\+QNWPREFCFG' | head -1 | tr -d '\r')"
    mode="$(_at      'AT+QNWPREFCFG="mode_pref"'  | grep '^\+QNWPREFCFG' | head -1 | tr -d '\r')"

    _parse_qcsq "$qcsq"

    printf '{"firmware":%s,"imei":%s,"creg":%s,"c5greg":%s,"at_port":%s,"technology":%s,"rssi":%s,"rsrp":%s,"sinr":%s,"rsrq":%s,"cell":%s,"lte_bands":%s,"nr5g_bands":%s,"mode":%s}' \
        "$(_json_str "$fw")"        "$(_json_str "$imei")"      \
        "$(_json_str "$creg")"      "$(_json_str "$c5greg")"    \
        "$(_json_str "$AT_PORT")"   "$(_json_str "$tech")"      \
        "$(_json_num "$rssi")"      "$(_json_num "$rsrp")"      \
        "$(_json_num "$sinr")"      "$(_json_num "$rsrq")"      \
        "$(_json_str "$cell")"      "$(_json_str "$lte_bands")" \
        "$(_json_str "$nr_bands")"  "$(_json_str "$mode")"
}

# Returns signal + cell only — used by the 10s auto-refresh poll.
_method_refresh() {
    _find_at_port || { printf '{"error":"AT port not found"}'; return; }

    local qcsq cell tech rssi rsrp sinr rsrq
    qcsq="$(_at "AT+QCSQ"               | grep '^\+QCSQ' | head -1 | sed 's/+QCSQ: //' | tr -d '\r"')"
    cell="$(_at 'AT+QENG="servingcell"' | grep '^\+QENG' | head -1 | tr -d '\r')"
    _parse_qcsq "$qcsq"

    printf '{"technology":%s,"rssi":%s,"rsrp":%s,"sinr":%s,"rsrq":%s,"cell":%s}' \
        "$(_json_str "$tech")"  "$(_json_num "$rssi")" "$(_json_num "$rsrp")" \
        "$(_json_num "$sinr")"  "$(_json_num "$rsrq")" "$(_json_str "$cell")"
}

# ── Individual methods (kept for direct use / debugging) ──────────────────

_method_status() {
    _find_at_port || { printf '{"error":"AT port not found"}'; return; }
    local fw imei creg c5greg
    fw="$(_at "ATI"        | grep -i 'revision' | head -1 | sed 's/.*Revision: *//' | tr -d '\r')"
    imei="$(_at "AT+GSN"   | grep -E '^[0-9]{15}' | head -1 | tr -d '\r')"
    creg="$(_at "AT+CREG?" | grep '+CREG:'  | head -1 | tr -d '\r')"
    c5greg="$(_at "AT+C5GREG?" | grep '+C5GREG:' | head -1 | tr -d '\r')"
    printf '{"firmware":%s,"imei":%s,"creg":%s,"c5greg":%s,"at_port":%s}' \
        "$(_json_str "$fw")" "$(_json_str "$imei")" "$(_json_str "$creg")" \
        "$(_json_str "$c5greg")" "$(_json_str "$AT_PORT")"
}

_method_signal() {
    _find_at_port || { printf '{"error":"AT port not found"}'; return; }
    local qcsq tech rssi rsrp sinr rsrq
    qcsq="$(_at "AT+QCSQ" | grep '^\+QCSQ' | head -1 | sed 's/+QCSQ: //' | tr -d '\r"')"
    _parse_qcsq "$qcsq"
    printf '{"technology":%s,"rssi":%s,"rsrp":%s,"sinr":%s,"rsrq":%s}' \
        "$(_json_str "$tech")" "$(_json_num "$rssi")" "$(_json_num "$rsrp")" \
        "$(_json_num "$sinr")" "$(_json_num "$rsrq")"
}

_method_cell() {
    _find_at_port || { printf '{"error":"AT port not found"}'; return; }
    local cell
    cell="$(_at 'AT+QENG="servingcell"' | grep '^\+QENG' | head -1 | tr -d '\r')"
    printf '{"raw":%s}' "$(_json_str "$cell")"
}

_method_bands() {
    _find_at_port || { printf '{"error":"AT port not found"}'; return; }
    local lte_bands nr_bands mode
    lte_bands="$(_at 'AT+QNWPREFCFG="lte_band"'  | grep '^\+QNWPREFCFG' | head -1 | tr -d '\r')"
    nr_bands="$(_at  'AT+QNWPREFCFG="nr5g_band"' | grep '^\+QNWPREFCFG' | head -1 | tr -d '\r')"
    mode="$(_at      'AT+QNWPREFCFG="mode_pref"' | grep '^\+QNWPREFCFG' | head -1 | tr -d '\r')"
    printf '{"lte_bands":%s,"nr5g_bands":%s,"mode":%s}' \
        "$(_json_str "$lte_bands")" "$(_json_str "$nr_bands")" "$(_json_str "$mode")"
}

_method_set_bands() {
    _find_at_port || { printf '{"error":"AT port not found"}'; return; }
    local lte_band="$1" nr_band="$2"
    [ -n "$lte_band" ] && _at "AT+QNWPREFCFG=\"lte_band\",${lte_band}" >/dev/null
    [ -n "$nr_band"  ] && _at "AT+QNWPREFCFG=\"nr5g_band\",${nr_band}" >/dev/null
    printf '{"result":"ok"}'
}

_method_reboot_modem() {
    _find_at_port || { printf '{"error":"AT port not found"}'; return; }
    _at 'AT+CFUN=1,1' >/dev/null
    printf '{"result":"rebooting"}'
}

_method_set_apn() {
    _find_at_port || { printf '{"error":"AT port not found"}'; return; }
    local apn="$1"
    [ -n "$apn" ] || { printf '{"error":"apn required"}'; return; }
    _at "AT+CGDCONT=1,\"IPV4V6\",\"${apn}\"" >/dev/null
    printf '{"result":"ok","apn":"%s"}' "$apn"
}

# ── JSON-RPC dispatcher ────────────────────────────────────────────────────

case "$1" in
    list)
        printf '{"full_status":{},"refresh":{},"status":{},"signal":{},"cell":{},"bands":{},"set_bands":{"lte_band":"","nr_band":""},"reboot_modem":{},"set_apn":{"apn":""}}'
        ;;
    call)
        case "$2" in
            full_status)   _method_full_status ;;
            refresh)       _method_refresh ;;
            status)        _method_status ;;
            signal)        _method_signal ;;
            cell)          _method_cell ;;
            bands)         _method_bands ;;
            set_bands)     _method_set_bands "$(jsonfilter -e '@.lte_band' 2>/dev/null)" "$(jsonfilter -e '@.nr_band' 2>/dev/null)" ;;
            reboot_modem)  _method_reboot_modem ;;
            set_apn)       _method_set_apn "$(jsonfilter -e '@.apn' 2>/dev/null)" ;;
            *)             printf '{"error":"unknown method"}' ;;
        esac
        ;;
esac
