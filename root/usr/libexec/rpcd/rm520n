#!/bin/sh
# rpcd backend for luci-app-rm520n

AT_PORT=""
AT_LOCK="/tmp/.rm520n_at_lock"

_find_at_port() {
    for p in /dev/ttyUSB2 /dev/ttyUSB3 /dev/ttyUSB1 /dev/ttyUSB0; do
        [ -c "$p" ] && AT_PORT="$p" && return 0
    done
    return 1
}

_at_lock() {
    local tries=0 owner
    while ! mkdir "$AT_LOCK" 2>/dev/null; do
        # If the owning process is dead, the lock is stale — remove it
        owner="$(cat "$AT_LOCK/pid" 2>/dev/null)"
        # Stale if: no pid file (old lock format), or pid file references a dead process
        if [ -z "$owner" ] || ! kill -0 "$owner" 2>/dev/null; then
            rm -rf "$AT_LOCK" 2>/dev/null
            continue
        fi
        tries=$(( tries + 1 ))
        [ "$tries" -ge 10 ] && return 1
        sleep 1
    done
    printf '%s' "$$" > "$AT_LOCK/pid"
}

_at_unlock() { rm -rf "$AT_LOCK" 2>/dev/null || true; }

# Send one AT command and return the full modem response.
#
# Opens and closes the tty fd on every call.  On Linux, closing the last
# file descriptor to a tty causes the kernel to flush the line-discipline
# input queue.  This prevents leftover bytes from a previous response
# from contaminating the next read.
#
# Caller must hold _at_lock for the duration of the containing method so
# the 10-second poll cannot interleave between sequential calls.
_at() {
    local cmd="$1" max="${2:-4}" tmpf="/tmp/_rm520n_at_$$" dpid i result

    exec 3<>"$AT_PORT"
    stty raw -F "$AT_PORT" 2>/dev/null || true
    dd <&3 of="$tmpf" bs=4096 count=65536 2>/dev/null &
    dpid=$!
    printf '%s\r\n' "$cmd" >&3
    i=0
    while [ "$i" -lt "$max" ]; do
        sleep 1; i=$(( i + 1 ))
        grep -qE 'OK|ERROR|NO CARRIER' "$tmpf" 2>/dev/null && break
    done
    kill "$dpid" 2>/dev/null || true
    wait "$dpid" 2>/dev/null || true
    exec 3>&- 2>/dev/null || true

    result="$(cat "$tmpf" 2>/dev/null)"
    rm -f "$tmpf"
    printf '%s' "$result"
}

_json_str() { printf '"%s"' "$(printf '%s' "$1" | sed 's/\\/\\\\/g;s/"/\\"/g')"; }
_json_num() {
    case "$1" in
        -[0-9]*|[0-9]*) printf '%s' "$1" ;;
        *) printf 'null' ;;
    esac
}

# ── AT response parsers ───────────────────────────────────────────────────────

# +QCSQ: "<tech>",rssi,rsrp,sinr,rsrq
# Sets globals: tech rssi rsrp sinr rsrq
_parse_qcsq() {
    local qcsq="$1"
    tech="$( printf '%s' "$qcsq" | cut -d, -f1)"
    rssi="$( printf '%s' "$qcsq" | cut -d, -f2)"
    rsrp="$( printf '%s' "$qcsq" | cut -d, -f3)"
    sinr="$( printf '%s' "$qcsq" | cut -d, -f4)"
    rsrq="$( printf '%s' "$qcsq" | cut -d, -f5)"
}

# +QENG: "servingcell","<rrc>","<rat>","<dup>",mcc,mnc,cell_id,pci,earfcn,
#         band,bw_ul,bw_dl,tac,rsrp,rsrq,rssi,sinr,cqi,tx_power
# Sets globals: qeng_rrc qeng_rat qeng_duplex qeng_mcc qeng_mnc
#               qeng_cell_id qeng_pci qeng_earfcn qeng_band qeng_tac
#               qeng_rsrp qeng_rsrq qeng_rssi qeng_sinr qeng_cqi qeng_tx_power
_parse_qeng() {
    local line="$1" data
    data="$(printf '%s' "$line" | sed 's/+QENG:[[:space:]]*//' | tr -d '"' | tr -d '\r')"
    qeng_rrc="$(      printf '%s' "$data" | cut -d, -f2)"
    qeng_rat="$(      printf '%s' "$data" | cut -d, -f3)"
    qeng_duplex="$(   printf '%s' "$data" | cut -d, -f4)"
    qeng_mcc="$(      printf '%s' "$data" | cut -d, -f5)"
    qeng_mnc="$(      printf '%s' "$data" | cut -d, -f6)"
    qeng_cell_id="$(  printf '%s' "$data" | cut -d, -f7)"
    qeng_pci="$(      printf '%s' "$data" | cut -d, -f8)"
    qeng_earfcn="$(   printf '%s' "$data" | cut -d, -f9)"
    qeng_band="$(     printf '%s' "$data" | cut -d, -f10)"
    qeng_tac="$(      printf '%s' "$data" | cut -d, -f13)"
    qeng_rsrp="$(     printf '%s' "$data" | cut -d, -f14)"
    qeng_rsrq="$(     printf '%s' "$data" | cut -d, -f15)"
    qeng_rssi="$(     printf '%s' "$data" | cut -d, -f16)"
    qeng_sinr="$(     printf '%s' "$data" | cut -d, -f17)"
    qeng_cqi="$(      printf '%s' "$data" | cut -d, -f18)"
    qeng_tx_power="$( printf '%s' "$data" | cut -d, -f19 | tr -d '\r')"
    [ "$qeng_cqi"      = "-" ] && qeng_cqi=""
    [ "$qeng_tx_power" = "-" ] && qeng_tx_power=""
}

# +QRSRP: rx0,rx1,rx2,rx3  (-140 = antenna not connected → null)
# Sets globals: rsrp_rx0 rsrp_rx1 rsrp_rx2 rsrp_rx3
_parse_qrsrp() {
    local raw="$1" data
    data="$(printf '%s' "$raw" | grep '+QRSRP:' | head -1 \
            | sed 's/+QRSRP:[[:space:]]*//' | tr -d ' \r')"
    rsrp_rx0="$(printf '%s' "$data" | cut -d, -f1)"
    rsrp_rx1="$(printf '%s' "$data" | cut -d, -f2)"
    rsrp_rx2="$(printf '%s' "$data" | cut -d, -f3)"
    rsrp_rx3="$(printf '%s' "$data" | cut -d, -f4)"
    [ "$rsrp_rx0" = "-140" ] && rsrp_rx0=""
    [ "$rsrp_rx1" = "-140" ] && rsrp_rx1=""
    [ "$rsrp_rx2" = "-140" ] && rsrp_rx2=""
    [ "$rsrp_rx3" = "-140" ] && rsrp_rx3=""
}

# +QTEMP: "sensor",value  (multiple lines)
# Sets globals: temp_xo temp_mdm temp_pa
# Patterns are intentionally broad to cover firmware naming variations
# (xo-therm vs xo-therm-buf, mdm-therm vs mdm-case-therm, pa-therm0 vs pa-therm1).
_parse_qtemp() {
    local raw="$1"
    temp_xo="$( printf '%s' "$raw" | grep '"xo-therm'  | head -1 | cut -d, -f2 | tr -d ' \r')"
    temp_mdm="$(printf '%s' "$raw" | grep '"mdm'        | head -1 | cut -d, -f2 | tr -d ' \r')"
    temp_pa="$( printf '%s' "$raw" | grep '"pa-therm'   | head -1 | cut -d, -f2 | tr -d ' \r')"
}

# +QNWINFO: "<duplex> <rat>","<plmn>","<rat> BAND <n>",<earfcn>
# Sets globals: qnwinfo_rat qnwinfo_duplex qnwinfo_mcc qnwinfo_mnc qnwinfo_band qnwinfo_earfcn
_parse_qnwinfo() {
    local raw="$1" line data tech_str plmn_str band_str
    line="$(printf '%s' "$raw" | grep '+QNWINFO:' | head -1)"
    [ -z "$line" ] && return
    data="$(printf '%s' "$line" | sed 's/+QNWINFO:[[:space:]]*//' | tr -d '"' | tr -d '\r')"
    tech_str="$(  printf '%s' "$data" | cut -d, -f1)"
    plmn_str="$(  printf '%s' "$data" | cut -d, -f2)"
    band_str="$(  printf '%s' "$data" | cut -d, -f3)"
    qnwinfo_earfcn="$(printf '%s' "$data" | cut -d, -f4)"
    qnwinfo_band="$(printf '%s' "$band_str" | sed 's/.*BAND[[:space:]]*//')"
    qnwinfo_duplex="$(printf '%s' "$tech_str" | awk '{print $1}')"
    qnwinfo_rat="$(   printf '%s' "$tech_str" | awk '{print $2}')"
    qnwinfo_mcc="$(   printf '%s' "$plmn_str" | cut -c1-3)"
    qnwinfo_mnc="$(   printf '%s' "$plmn_str" | cut -c4-)"
}

# +COPS: 0,0,"Operator name",7
# Sets global: operator
_parse_cops() {
    local raw="$1"
    operator="$(printf '%s' "$raw" | grep '+COPS:' | head -1 \
                | sed 's/.*"\(.*\)".*/\1/' | tr -d '\r')"
}

# +QGDCNT: tx_bytes,rx_bytes
# Sets globals: modem_tx modem_rx
_parse_qgdcnt() {
    local raw="$1" data
    data="$(printf '%s' "$raw" | grep '+QGDCNT:' | head -1 \
            | sed 's/+QGDCNT:[[:space:]]*//' | tr -d ' \r')"
    modem_tx="$(printf '%s' "$data" | cut -d, -f1)"
    modem_rx="$(printf '%s' "$data" | cut -d, -f2)"
}

# +QCAINFO: "pcc|scc",earfcn,bw,"LTE BAND N",dl_state,pci,rsrp,rsrq,rssi,sinr
# Builds and prints a JSON array (or null if no data).
_build_ca_json() {
    local raw="$1" tmpf="/tmp/_rm520n_ca_$$" _first _line _data
    local _type _earfcn _bw _band_str _band _pci _rsrp _rsrq _rssi _sinr

    printf '%s' "$raw" | grep '^+QCAINFO' | while IFS= read -r _line; do
        _data="$(printf '%s' "$_line" | sed 's/+QCAINFO:[[:space:]]*//' | tr -d '"' | tr -d '\r')"
        _type="$(    printf '%s' "$_data" | cut -d, -f1)"
        _earfcn="$(  printf '%s' "$_data" | cut -d, -f2)"
        _bw="$(      printf '%s' "$_data" | cut -d, -f3)"
        _band_str="$(printf '%s' "$_data" | cut -d, -f4)"
        _band="$(    printf '%s' "$_band_str" | sed 's/.*BAND[[:space:]]*//')"
        _pci="$(     printf '%s' "$_data" | cut -d, -f6)"
        _rsrp="$(    printf '%s' "$_data" | cut -d, -f7)"
        _rsrq="$(    printf '%s' "$_data" | cut -d, -f8)"
        _rssi="$(    printf '%s' "$_data" | cut -d, -f9)"
        _sinr="$(    printf '%s' "$_data" | cut -d, -f10 | tr -d '\r')"
        printf '%s|%s|%s|%s|%s|%s|%s|%s|%s\n' \
            "$_type" "$_earfcn" "$_bw" "$_band" "$_pci" "$_rsrp" "$_rsrq" "$_rssi" "$_sinr"
    done > "$tmpf"

    if [ -s "$tmpf" ]; then
        printf '['
        _first=1
        while IFS='|' read -r _type _earfcn _bw _band _pci _rsrp _rsrq _rssi _sinr; do
            [ "$_first" -eq 0 ] && printf ','
            printf '{"type":%s,"earfcn":%s,"bw":%s,"band":%s,"pci":%s,"rsrp":%s,"rsrq":%s,"rssi":%s,"sinr":%s}' \
                "$(_json_str "$_type")" \
                "$(_json_num "$_earfcn")" "$(_json_num "$_bw")"  "$(_json_num "$_band")" \
                "$(_json_num "$_pci")"   "$(_json_num "$_rsrp")" "$(_json_num "$_rsrq")" \
                "$(_json_num "$_rssi")"  "$(_json_num "$_sinr")"
            _first=0
        done < "$tmpf"
        printf ']'
    else
        printf 'null'
    fi
    rm -f "$tmpf"
}

# +CREG: <n>,<stat>[,...] → human-readable registration status
_parse_reg_stat() {
    local raw="$1" stat
    stat="$(printf '%s' "$raw" | cut -d, -f2 | tr -d ' \r')"
    case "$stat" in
        0) printf 'Not registered' ;;
        1) printf 'Registered (home)' ;;
        2) printf 'Searching' ;;
        3) printf 'Denied' ;;
        4) printf 'Unknown' ;;
        5) printf 'Registered (roaming)' ;;
        *) printf '%s' "$raw" ;;
    esac
}

# ── Combined methods ──────────────────────────────────────────────────────────

# Full status — used on page load.
# All 15 AT commands are sent in one locked session without waiting between
# them. The modem queues and processes them in order, so we only need to
# sleep once (waiting for the last response) instead of sleeping once per
# command. Typical latency: ~2s instead of ~15s.
_method_full_status() {
    _find_at_port || { printf '{"error":"AT port not found"}'; return; }
    _at_lock      || { printf '{"error":"AT port busy"}';      return; }

    local tmpf="/tmp/_rm520n_fs_$$" dpid i raw
    local fw imei creg_raw c5greg_raw qcsq_raw cell_raw
    local lte_bands nr_bands mode
    local tech rssi rsrp sinr rsrq
    local qeng_rrc qeng_rat qeng_duplex qeng_mcc qeng_mnc
    local qeng_cell_id qeng_pci qeng_earfcn qeng_band qeng_tac
    local qeng_rsrp qeng_rsrq qeng_rssi qeng_sinr qeng_cqi qeng_tx_power
    local rsrp_rx0 rsrp_rx1 rsrp_rx2 rsrp_rx3
    local temp_xo temp_mdm temp_pa
    local operator modem_tx modem_rx
    local qnwinfo_rat qnwinfo_duplex qnwinfo_mcc qnwinfo_mnc qnwinfo_band qnwinfo_earfcn
    local creg c5greg ca_json

    exec 3<>"$AT_PORT"
    stty raw -F "$AT_PORT" 2>/dev/null || true
    dd <&3 of="$tmpf" bs=4096 count=65536 2>/dev/null &
    dpid=$!

    # Send all commands without waiting — modem processes them in order
    printf 'AT+GMR\r\n'                        >&3
    printf 'AT+GSN\r\n'                        >&3
    printf 'AT+CREG?\r\n'                      >&3
    printf 'AT+C5GREG?\r\n'                    >&3
    printf 'AT+COPS?\r\n'                      >&3
    printf 'AT+QCSQ\r\n'                       >&3
    printf 'AT+QENG="servingcell"\r\n'         >&3
    printf 'AT+QNWINFO\r\n'                    >&3
    printf 'AT+QRSRP\r\n'                      >&3
    printf 'AT+QCAINFO\r\n'                    >&3
    printf 'AT+QTEMP\r\n'                      >&3
    printf 'AT+QGDCNT?\r\n'                    >&3
    printf 'AT+QNWPREFCFG="lte_band"\r\n'      >&3
    printf 'AT+QNWPREFCFG="nr5g_band"\r\n'     >&3
    printf 'AT+QNWPREFCFG="mode_pref"\r\n'     >&3

    # Wait until all 15 commands have responded (each ends with OK or ERROR),
    # up to 8 seconds total. Also catches +CME ERROR responses.
    i=0
    while [ "$i" -lt 8 ]; do
        sleep 1; i=$(( i + 1 ))
        [ "$(grep -cE '^(OK|ERROR|\+CME ERROR)' "$tmpf" 2>/dev/null || echo 0)" -ge 15 ] && break
    done

    kill "$dpid" 2>/dev/null || true
    wait "$dpid" 2>/dev/null || true
    exec 3>&- 2>/dev/null || true
    _at_unlock

    raw="$(cat "$tmpf" 2>/dev/null)"
    rm -f "$tmpf"

    # If modem returned no data at all — AT port present but modem not responding
    [ -z "$raw" ] && { printf '{"error":"modem not responding"}'; return; }

    # Extract per-command data from the combined response
    fw="$(        printf '%s' "$raw" | grep -E '^RM'        | head -1 | tr -d '\r')"
    imei="$(      printf '%s' "$raw" | grep -E '^[0-9]{15}' | head -1 | tr -d '\r')"
    creg_raw="$(  printf '%s' "$raw" | grep '+CREG:'        | head -1 | tr -d '\r')"
    c5greg_raw="$(printf '%s' "$raw" | grep '+C5GREG:'      | head -1 | tr -d '\r')"
    qcsq_raw="$(  printf '%s' "$raw" | grep '^+QCSQ'        | head -1 | sed 's/+QCSQ: //' | tr -d '\r"')"
    cell_raw="$(  printf '%s' "$raw" | grep '^+QENG'        | head -1 | tr -d '\r')"
    # QNWPREFCFG responses include the param name — extract value after the comma
    lte_bands="$( printf '%s' "$raw" | grep '+QNWPREFCFG: "lte_band"'  | sed 's/.*"lte_band",//'  | tr -d '\r')"
    nr_bands="$(  printf '%s' "$raw" | grep '+QNWPREFCFG: "nr5g_band"' | sed 's/.*"nr5g_band",//' | tr -d '\r')"
    mode="$(      printf '%s' "$raw" | grep '+QNWPREFCFG: "mode_pref"' | sed 's/.*"mode_pref",/'  | tr -d '\r')"

    # Parsers that do their own internal grep on the full combined output
    _parse_qcsq    "$qcsq_raw"
    _parse_qeng    "$cell_raw"
    _parse_qnwinfo "$raw"
    _parse_qrsrp   "$raw"
    _parse_qtemp   "$raw"
    _parse_cops    "$raw"
    _parse_qgdcnt  "$raw"
    creg="$(   _parse_reg_stat "$creg_raw")"
    c5greg="$( _parse_reg_stat "$c5greg_raw")"
    ca_json="$(_build_ca_json  "$raw")"

    printf '{'
    printf '"firmware":%s,'    "$(_json_str "$fw")"
    printf '"imei":%s,'        "$(_json_str "$imei")"
    printf '"at_port":%s,'     "$(_json_str "$AT_PORT")"
    printf '"creg":%s,'        "$(_json_str "$creg")"
    printf '"c5greg":%s,'      "$(_json_str "$c5greg")"
    printf '"operator":%s,'    "$(_json_str "$operator")"
    printf '"technology":%s,'  "$(_json_str "$tech")"
    printf '"rssi":%s,'        "$(_json_num "$rssi")"
    printf '"rsrp":%s,'        "$(_json_num "$rsrp")"
    printf '"sinr":%s,'        "$(_json_num "$sinr")"
    printf '"rsrq":%s,'        "$(_json_num "$rsrq")"
    printf '"rrc_state":%s,'   "$(_json_str "$qeng_rrc")"
    printf '"rat":%s,'         "$(_json_str "${qeng_rat:-$qnwinfo_rat}")"
    printf '"duplex":%s,'      "$(_json_str "${qeng_duplex:-$qnwinfo_duplex}")"
    printf '"mcc":%s,'         "$(_json_str "${qeng_mcc:-$qnwinfo_mcc}")"
    printf '"mnc":%s,'         "$(_json_str "${qeng_mnc:-$qnwinfo_mnc}")"
    printf '"cell_id":%s,'     "$(_json_str "$qeng_cell_id")"
    printf '"pci":%s,'         "$(_json_num "$qeng_pci")"
    printf '"earfcn":%s,'      "$(_json_num "${qeng_earfcn:-$qnwinfo_earfcn}")"
    printf '"band":%s,'        "$(_json_num "${qeng_band:-$qnwinfo_band}")"
    printf '"tac":%s,'         "$(_json_str "$qeng_tac")"
    printf '"cqi":%s,'         "$(_json_num "$qeng_cqi")"
    printf '"tx_power":%s,'    "$(_json_num "$qeng_tx_power")"
    printf '"rsrp_rx0":%s,'    "$(_json_num "$rsrp_rx0")"
    printf '"rsrp_rx1":%s,'    "$(_json_num "$rsrp_rx1")"
    printf '"rsrp_rx2":%s,'    "$(_json_num "$rsrp_rx2")"
    printf '"rsrp_rx3":%s,'    "$(_json_num "$rsrp_rx3")"
    printf '"temp_xo":%s,'     "$(_json_num "$temp_xo")"
    printf '"temp_mdm":%s,'    "$(_json_num "$temp_mdm")"
    printf '"temp_pa":%s,'     "$(_json_num "$temp_pa")"
    printf '"modem_tx":%s,'    "$(_json_num "$modem_tx")"
    printf '"modem_rx":%s,'    "$(_json_num "$modem_rx")"
    printf '"ca":%s,'          "$ca_json"
    printf '"lte_bands":%s,'   "$(_json_str "$lte_bands")"
    printf '"nr5g_bands":%s,'  "$(_json_str "$nr_bands")"
    printf '"mode":%s'         "$(_json_str "$mode")"
    printf '}'
}

# Live refresh — signal + cell detail + per-antenna RSRP. Used by 10s poll.
# Uses the same bulk-send approach as full_status: all 3 commands sent at once.
_method_refresh() {
    _find_at_port || { printf '{"error":"AT port not found"}'; return; }
    _at_lock      || { printf '{"error":"AT port busy"}';      return; }

    local tmpf="/tmp/_rm520n_rf_$$" dpid i raw qcsq_raw cell_raw
    local tech rssi rsrp sinr rsrq
    local qeng_rrc qeng_rat qeng_duplex qeng_mcc qeng_mnc
    local qeng_cell_id qeng_pci qeng_earfcn qeng_band qeng_tac
    local qeng_rsrp qeng_rsrq qeng_rssi qeng_sinr qeng_cqi qeng_tx_power
    local rsrp_rx0 rsrp_rx1 rsrp_rx2 rsrp_rx3

    exec 3<>"$AT_PORT"
    stty raw -F "$AT_PORT" 2>/dev/null || true
    dd <&3 of="$tmpf" bs=4096 count=65536 2>/dev/null &
    dpid=$!

    printf 'AT+QCSQ\r\n'               >&3
    printf 'AT+QENG="servingcell"\r\n' >&3
    printf 'AT+QRSRP\r\n'              >&3

    # Wait for all 3 responses, up to 4s
    i=0
    while [ "$i" -lt 4 ]; do
        sleep 1; i=$(( i + 1 ))
        [ "$(grep -cE '^(OK|ERROR|\+CME ERROR)' "$tmpf" 2>/dev/null || echo 0)" -ge 3 ] && break
    done

    kill "$dpid" 2>/dev/null || true
    wait "$dpid" 2>/dev/null || true
    exec 3>&- 2>/dev/null || true
    _at_unlock

    raw="$(cat "$tmpf" 2>/dev/null)"
    rm -f "$tmpf"

    [ -z "$raw" ] && { printf '{"error":"modem not responding"}'; return; }

    qcsq_raw="$(printf '%s' "$raw" | grep '^+QCSQ' | head -1 | sed 's/+QCSQ: //' | tr -d '\r"')"
    cell_raw="$(printf '%s' "$raw" | grep '^+QENG' | head -1 | tr -d '\r')"

    _parse_qcsq  "$qcsq_raw"
    _parse_qeng  "$cell_raw"
    _parse_qrsrp "$raw"

    printf '{'
    printf '"technology":%s,' "$(_json_str "$tech")"
    printf '"rssi":%s,'       "$(_json_num "$rssi")"
    printf '"rsrp":%s,'       "$(_json_num "$rsrp")"
    printf '"sinr":%s,'       "$(_json_num "$sinr")"
    printf '"rsrq":%s,'       "$(_json_num "$rsrq")"
    printf '"rrc_state":%s,'  "$(_json_str "$qeng_rrc")"
    printf '"rat":%s,'        "$(_json_str "$qeng_rat")"
    printf '"cell_id":%s,'    "$(_json_str "$qeng_cell_id")"
    printf '"pci":%s,'        "$(_json_num "$qeng_pci")"
    printf '"earfcn":%s,'     "$(_json_num "$qeng_earfcn")"
    printf '"band":%s,'       "$(_json_num "$qeng_band")"
    printf '"rsrp_rx0":%s,'   "$(_json_num "$rsrp_rx0")"
    printf '"rsrp_rx1":%s,'   "$(_json_num "$rsrp_rx1")"
    printf '"rsrp_rx2":%s,'   "$(_json_num "$rsrp_rx2")"
    printf '"rsrp_rx3":%s'    "$(_json_num "$rsrp_rx3")"
    printf '}'
}

# ── Individual methods (direct use / debugging) ───────────────────────────────

_method_status() {
    _find_at_port || { printf '{"error":"AT port not found"}'; return; }
    _at_lock      || { printf '{"error":"AT port busy"}';      return; }
    local fw imei creg_raw c5greg_raw creg c5greg
    fw="$(       _at "AT+GMR"     | grep -E '^RM'        | head -1 | tr -d '\r')"
    imei="$(     _at "AT+GSN"     | grep -E '^[0-9]{15}' | head -1 | tr -d '\r')"
    creg_raw="$( _at "AT+CREG?"  | grep '+CREG:'         | head -1 | tr -d '\r')"
    c5greg_raw="$(_at "AT+C5GREG?" | grep '+C5GREG:'     | head -1 | tr -d '\r')"
    _at_unlock
    creg="$(  _parse_reg_stat "$creg_raw")"
    c5greg="$(_parse_reg_stat "$c5greg_raw")"
    printf '{"firmware":%s,"imei":%s,"creg":%s,"c5greg":%s,"at_port":%s}' \
        "$(_json_str "$fw")" "$(_json_str "$imei")" \
        "$(_json_str "$creg")" "$(_json_str "$c5greg")" "$(_json_str "$AT_PORT")"
}

_method_signal() {
    _find_at_port || { printf '{"error":"AT port not found"}'; return; }
    _at_lock      || { printf '{"error":"AT port busy"}';      return; }
    local qcsq_raw tech rssi rsrp sinr rsrq
    qcsq_raw="$(_at "AT+QCSQ" | grep '^+QCSQ' | head -1 | sed 's/+QCSQ: //' | tr -d '\r"')"
    _at_unlock
    _parse_qcsq "$qcsq_raw"
    printf '{"technology":%s,"rssi":%s,"rsrp":%s,"sinr":%s,"rsrq":%s}' \
        "$(_json_str "$tech")" "$(_json_num "$rssi")" "$(_json_num "$rsrp")" \
        "$(_json_num "$sinr")" "$(_json_num "$rsrq")"
}

_method_cell() {
    _find_at_port || { printf '{"error":"AT port not found"}'; return; }
    _at_lock      || { printf '{"error":"AT port busy"}';      return; }
    local cell_raw
    local qeng_rrc qeng_rat qeng_duplex qeng_mcc qeng_mnc
    local qeng_cell_id qeng_pci qeng_earfcn qeng_band qeng_tac
    local qeng_rsrp qeng_rsrq qeng_rssi qeng_sinr qeng_cqi qeng_tx_power
    cell_raw="$(_at 'AT+QENG="servingcell"' | grep '^+QENG' | head -1 | tr -d '\r')"
    _at_unlock
    _parse_qeng "$cell_raw"
    printf '{"rrc_state":%s,"rat":%s,"duplex":%s,"mcc":%s,"mnc":%s,"cell_id":%s,"pci":%s,"earfcn":%s,"band":%s,"tac":%s,"rsrp":%s,"rsrq":%s,"rssi":%s,"sinr":%s,"cqi":%s,"tx_power":%s}' \
        "$(_json_str "$qeng_rrc")"   "$(_json_str "$qeng_rat")"    "$(_json_str "$qeng_duplex")" \
        "$(_json_str "$qeng_mcc")"   "$(_json_str "$qeng_mnc")"    "$(_json_str "$qeng_cell_id")" \
        "$(_json_num "$qeng_pci")"   "$(_json_num "$qeng_earfcn")" "$(_json_num "$qeng_band")" \
        "$(_json_str "$qeng_tac")"   "$(_json_num "$qeng_rsrp")"   "$(_json_num "$qeng_rsrq")" \
        "$(_json_num "$qeng_rssi")"  "$(_json_num "$qeng_sinr")"   "$(_json_num "$qeng_cqi")" \
        "$(_json_num "$qeng_tx_power")"
}

_method_bands() {
    _find_at_port || { printf '{"error":"AT port not found"}'; return; }
    _at_lock      || { printf '{"error":"AT port busy"}';      return; }
    local lte_bands nr_bands mode
    lte_bands="$(_at 'AT+QNWPREFCFG="lte_band"'  | grep '^+QNWPREFCFG' | head -1 | tr -d '\r' | sed 's/[^,]*,//')"
    nr_bands="$(  _at 'AT+QNWPREFCFG="nr5g_band"' | grep '^+QNWPREFCFG' | head -1 | tr -d '\r' | sed 's/[^,]*,//')"
    mode="$(      _at 'AT+QNWPREFCFG="mode_pref"' | grep '^+QNWPREFCFG' | head -1 | tr -d '\r' | sed 's/[^,]*,//')"
    _at_unlock
    printf '{"lte_bands":%s,"nr5g_bands":%s,"mode":%s}' \
        "$(_json_str "$lte_bands")" "$(_json_str "$nr_bands")" "$(_json_str "$mode")"
}

_method_set_bands() {
    _find_at_port || { printf '{"error":"AT port not found"}'; return; }
    _at_lock      || { printf '{"error":"AT port busy"}';      return; }
    local lte_band="$1" nr_band="$2"
    [ -n "$lte_band" ] && _at "AT+QNWPREFCFG=\"lte_band\",${lte_band}" >/dev/null
    [ -n "$nr_band"  ] && _at "AT+QNWPREFCFG=\"nr5g_band\",${nr_band}" >/dev/null
    _at_unlock
    printf '{"result":"ok"}'
}

_method_reboot_modem() {
    _find_at_port || { printf '{"error":"AT port not found"}'; return; }
    _at_lock      || { printf '{"error":"AT port busy"}';      return; }
    _at 'AT+CFUN=1,1' >/dev/null
    _at_unlock
    printf '{"result":"rebooting"}'
}

_method_set_apn() {
    _find_at_port || { printf '{"error":"AT port not found"}'; return; }
    _at_lock      || { printf '{"error":"AT port busy"}';      return; }
    local apn="$1"
    if [ -z "$apn" ]; then
        _at_unlock
        printf '{"error":"apn required"}'
        return
    fi
    _at "AT+CGDCONT=1,\"IPV4V6\",\"${apn}\"" >/dev/null
    _at_unlock
    printf '{"result":"ok","apn":"%s"}' "$apn"
}

# ── JSON-RPC dispatcher ────────────────────────────────────────────────────────

case "$1" in
    list)
        printf '{"full_status":{},"refresh":{},"status":{},"signal":{},"cell":{},"bands":{},"set_bands":{"lte_band":"","nr_band":""},"reboot_modem":{},"set_apn":{"apn":""}}'
        ;;
    call)
        case "$2" in
            full_status)   _method_full_status ;;
            refresh)       _method_refresh ;;
            status)        _method_status ;;
            signal)        _method_signal ;;
            cell)          _method_cell ;;
            bands)         _method_bands ;;
            set_bands)     _method_set_bands "$(jsonfilter -e '@.lte_band' 2>/dev/null)" "$(jsonfilter -e '@.nr_band' 2>/dev/null)" ;;
            reboot_modem)  _method_reboot_modem ;;
            set_apn)       _method_set_apn "$(jsonfilter -e '@.apn' 2>/dev/null)" ;;
            *)             printf '{"error":"unknown method"}' ;;
        esac
        ;;
esac
